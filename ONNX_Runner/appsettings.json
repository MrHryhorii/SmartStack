{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PhonemizerSettings": {
    "SupportedLanguages": ["en", "uk"],
    "UseLanguageDetector": true,
    "MaxBonusMultiplier": 0.50,
    "BonusMinLetterCount": 8,
    "BonusMaxLetterCount": 32
  },
  "ChunkerSettings": {
    "MinChunkLength": 350,
    "MaxChunkLength": 450
  },
  "HardwareSettings": {
    "TotalVramGb": 8.0,
    "VramPerRequestGb": 0.6,
    "CpuCoresUsageMultiplier": 0.75,
    "OpenVoiceChunkSeconds": 15
  }
}
