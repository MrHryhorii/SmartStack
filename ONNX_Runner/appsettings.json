{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CorsSettings": {
    "AllowAnyOrigin": true,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      
      "http://localhost:8000",
      "http://127.0.0.1:8000",

      "http://localhost:5001",
      "http://127.0.0.1:5001",

      "http://localhost:11434",
      "http://127.0.0.1:11434",

      "http://localhost:7860",
      "http://127.0.0.1:7860",

      "http://localhost:1234",
      "http://127.0.0.1:1234",

      "http://localhost:8080",
      "http://127.0.0.1:8080",

      "http://localhost:3001",
      "http://127.0.0.1:3001",

      "http://localhost:3210",
      "http://127.0.0.1:3210",

      "http://localhost:1337",
      "http://127.0.0.1:1337",

      "http://localhost:5173",
      "http://127.0.0.1:5173",

      "https://hoppscotch.io",
      "https://chat.openai.com"
    ]
  },
  "PhonemizerSettings": {
    "SupportedLanguages": ["en", "uk"],
    "UseLanguageDetector": true,
    "MaxBonusMultiplier": 0.50,
    "BonusMinLetterCount": 8,
    "BonusMaxLetterCount": 32
  },
  "ChunkerSettings": {
    "MaxChunkLength": 250,
    "SentencePauseSeconds": 0.33
  },
  "HardwareSettings": {
    "TotalVramGb": 8.0,
    "VramPerRequestGb": 0.6,
    "CpuCoresUsageMultiplier": 0.5
  },
  "DspSettings": {
    "EnableLowPassFilter": true,
    "LowPassCutoffFrequency": 7500.0,
    "LowPassQFactor": 0.707
  },
  "StreamSettings": {
    "EnableStreaming": true,
    "FlushAfterEachSentence": true,
    "MinChunkSizeKb": 8
  }
}
