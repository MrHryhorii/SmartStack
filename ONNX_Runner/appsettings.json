{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PhonemizerSettings": {
    "SupportedLanguages": ["en", "uk"],
    "UseLanguageDetector": true,
    "MaxBonusMultiplier": 0.50,
    "BonusMinLetterCount": 8,
    "BonusMaxLetterCount": 32
  },
  "HardwareSettings": {
    "TotalVramGb": 8.0,
    "VramPerRequestGb": 1.5,
    "CpuCoresUsageMultiplier": 0.75
  }
}
